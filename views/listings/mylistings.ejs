<% layout("/layouts/boilerplate") %>

<h2 class="mb-3 mt-2">My Listings</h2>

<% if(listings.length === 0){ %>

  <div class="text-center mt-5">
    <h3>You haven't created any listings yet.</h3>

    <a href="/listings/new" class="btn btn-dark mt-3">
      Create Your First Listing
    </a>
  </div>

<% } %>

<div class="row row-cols-lg-3 row-cols-md-2 mt-2">
  <% for(let listing of listings){ %>

    <a href="/listings/<%= listing._id %>" class="listing-link">
        <div class="card col listing-card">
        <img src="<%= listing.image.url %>" class="card-img-top" alt="listing-image" style="height: 20rem;">
        <div class="card-img-overlay"><%= listing.country %></div>
          <div class="card-body">
            <p class="card-text">
              <b><%= listing.title %></b>
              <br>
              &#8377; <i class="actual-price"><%= listing.price.toLocaleString("en-IN")%> /night (exclusive of taxes)</i>
            </p>
          </div>
        </div>
    </a>

  <% } %>
</div>